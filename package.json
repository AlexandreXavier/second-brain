{
  "name": "video-second-brain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite --host localhost\" \"wait-on http://localhost:5173 && electron/node_modules/.bin/electron electron/main.js\"",
    "electron:build": "npm run build && cd electron && npm run build"
  },
  "dependencies": {
    "firebase": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "latest"
  }
}
