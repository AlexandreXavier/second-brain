# Copy this file to keystore.properties (same directory) and fill in the values.
# keystore.properties is gitignored — never commit the real file.
#
# storeFile: absolute path to the upload keystore (.keystore or .jks).
#   Recommended: keep it OUTSIDE the repo, e.g. ~/.android-keystores/segundo-cerebro-upload.keystore
# storePassword: the keystore (store) password set during keytool -genkey
# keyAlias: the key alias inside the keystore (e.g. "upload")
# keyPassword: the key password (often the same as storePassword)

storeFile=/Users/your-user/.android-keystores/segundo-cerebro-upload.keystore
storePassword=REPLACE_ME
keyAlias=upload
keyPassword=REPLACE_ME
